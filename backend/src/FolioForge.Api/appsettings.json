{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=localhost;Initial Catalog=folioforge;Integrated Security=True;TrustServerCertificate=True;Pooling=True",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Secret": "OVERRIDE_VIA_USER_SECRETS_OR_ENV",
    "Issuer": "FolioForge",
    "Audience": "FolioForge.Client",
    "AccessTokenExpirationMinutes": "15",
    "RefreshTokenExpirationDays": "7"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Bulkhead": {
    "Enabled": true,
    "Partitions": {
      "Default": {
        "MaxConcurrency": 50,
        "MaxQueueSize": 100,
        "QueueTimeoutMs": 5000
      },
      "Upload": {
        "MaxConcurrency": 5,
        "MaxQueueSize": 10,
        "QueueTimeoutMs": 10000
      },
      "Auth": {
        "MaxConcurrency": 20,
        "MaxQueueSize": 50,
        "QueueTimeoutMs": 3000
      }
    }
  },
  "CircuitBreaker": {
    "Enabled": true,
    "Breakers": {
      "GroqAi": {
        "FailureThreshold": 3,
        "OpenDurationSeconds": 30,
        "HalfOpenMaxAttempts": 2,
        "SuccessThresholdInHalfOpen": 2,
        "HandledExceptionTypes": ["HttpRequestException", "TaskCanceledException"]
      },
      "RabbitMq": {
        "FailureThreshold": 5,
        "OpenDurationSeconds": 15,
        "HalfOpenMaxAttempts": 1,
        "SuccessThresholdInHalfOpen": 1
      }
    }
  },
  "RateLimiting": {
    "Enabled": true,
    "KeyPrefix": "rl",
    "IncludeHeadersOnSuccess": true,
    "Whitelist": [],
    "Policies": {
      "Default": {
        "BucketCapacity": 20,
        "RefillRate": 10,
        "RefillIntervalSeconds": 1.0
      },
      "Auth": {
        "BucketCapacity": 5,
        "RefillRate": 2,
        "RefillIntervalSeconds": 1.0
      },
      "Upload": {
        "BucketCapacity": 3,
        "RefillRate": 1,
        "RefillIntervalSeconds": 2.0
      },
      "Strict": {
        "BucketCapacity": 5,
        "RefillRate": 1,
        "RefillIntervalSeconds": 1.0
      }
    }
  },
  "OpenTelemetry": {
    "ServiceName": "FolioForge.Api",
    "OtlpEndpoint": "http://localhost:4317",
    "Sampling": { "SuccessRatio": 0.01, "AlwaysSampleErrors": true }
  },
  "RabbitMq": {
    "HostName": "localhost",
    "QueueName": "resume_processing_queue"
  },
  "Gemini": { "ApiKey": "", "Model": "gemini-2.0-flash" },
  "Groq": { "ApiKey": "", "Model": "llama-3.3-70b-versatile", "Endpoint": "https://api.groq.com/openai/v1/chat/completions" },
  "OpenAi": { "ApiKey": "", "Model": "gpt-4o-mini" },
  "Razorpay": {
    "KeyId": "OVERRIDE_VIA_USER_SECRETS_OR_ENV",
    "KeySecret": "OVERRIDE_VIA_USER_SECRETS_OR_ENV",
    "WebhookSecret": "OVERRIDE_VIA_USER_SECRETS_OR_ENV"
  },
  "AllowedHosts": "*"
}
