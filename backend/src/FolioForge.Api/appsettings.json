{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=localhost;Initial Catalog=folioforge;Integrated Security=True;TrustServerCertificate=True;Pooling=True",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Secret": "FolioForge-SuperSecret-Key-That-Is-At-Least-32-Chars-Long!!",
    "Issuer": "FolioForge",
    "Audience": "FolioForge.Client",
    "ExpirationMinutes": "1440"
  },
  "Bulkhead": {
    "Enabled": true,
    "Partitions": {
      "Default": {
        "MaxConcurrency": 50,
        "MaxQueueSize": 100,
        "QueueTimeoutMs": 5000
      },
      "Upload": {
        "MaxConcurrency": 5,
        "MaxQueueSize": 10,
        "QueueTimeoutMs": 10000
      },
      "Auth": {
        "MaxConcurrency": 20,
        "MaxQueueSize": 50,
        "QueueTimeoutMs": 3000
      }
    }
  },
  "CircuitBreaker": {
    "Enabled": true,
    "Breakers": {
      "GroqAi": {
        "FailureThreshold": 3,
        "OpenDurationSeconds": 30,
        "HalfOpenMaxAttempts": 2,
        "SuccessThresholdInHalfOpen": 2,
        "HandledExceptionTypes": ["HttpRequestException", "TaskCanceledException"]
      },
      "RabbitMq": {
        "FailureThreshold": 5,
        "OpenDurationSeconds": 15,
        "HalfOpenMaxAttempts": 1,
        "SuccessThresholdInHalfOpen": 1
      }
    }
  },
  "RateLimiting": {
    "Enabled": true,
    "KeyPrefix": "rl",
    "IncludeHeadersOnSuccess": true,
    "Whitelist": [],
    "Policies": {
      "Default": {
        "BucketCapacity": 20,
        "RefillRate": 10,
        "RefillIntervalSeconds": 1.0
      },
      "Auth": {
        "BucketCapacity": 5,
        "RefillRate": 2,
        "RefillIntervalSeconds": 1.0
      },
      "Upload": {
        "BucketCapacity": 3,
        "RefillRate": 1,
        "RefillIntervalSeconds": 2.0
      },
      "Strict": {
        "BucketCapacity": 5,
        "RefillRate": 1,
        "RefillIntervalSeconds": 1.0
      }
    }
  },
  "AllowedHosts": "*"
}
