{
    "version": "2.0.0",
    "tasks": [
        // ── .NET Backend ──
        {
            "label": "build-api",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/backend/src/FolioForge.Api/FolioForge.Api.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile",
            "group": "build"
        },
        {
            "label": "build-worker",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/backend/src/FolioForge.Worker/FolioForge.Worker.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile",
            "group": "build"
        },
        {
            "label": "build-all-backend",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/backend/FolioForge.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        // ── Frontend ──
        {
            "label": "npm-install",
            "type": "shell",
            "command": "npm install",
            "options": {
                "cwd": "${workspaceFolder}/folioforge.client"
            },
            "problemMatcher": []
        },
        {
            "label": "dev-frontend",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/folioforge.client"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "VITE",
                    "endsPattern": "ready in"
                }
            }
        },
        // ── EF Core Migrations ──
        {
            "label": "ef-update-database",
            "type": "process",
            "command": "dotnet",
            "args": [
                "ef",
                "database",
                "update",
                "--project",
                "${workspaceFolder}/backend/src/FolioForge.Infrastructure/FolioForge.Infrastructure.csproj",
                "--startup-project",
                "${workspaceFolder}/backend/src/FolioForge.Api/FolioForge.Api.csproj"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
